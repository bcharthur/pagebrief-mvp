APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-super-secret
APP_ACCESS_TOKEN_EXPIRE_MINUTES=1440

POSTGRES_DB=pagebrief
POSTGRES_USER=pagebrief
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+psycopg://pagebrief:change-me-db-password@postgres:5432/pagebrief

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_S=180

FREE_DAILY_ANALYSES=5
FREE_ALLOWED_FORMATS=express
PREMIUM_ALLOWED_FORMATS=express,analytique,decision,etude
MAX_UPLOAD_MB=25
PDF_OVERVIEW_THRESHOLD=50000
MAX_INPUT_CHARS=7000

CORS_ALLOWED_ORIGINS=chrome-extension://*,http://localhost:3000

STORAGE_ROOT=/app/storage
LOG_LEVEL=INFO
