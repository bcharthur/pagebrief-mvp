{
  "manifest_version": 3,
  "name": "PageBrief",
  "version": "0.1.1",
  "description": "Résumé utile d'une page web en 1 clic.",
  "action": {
    "default_title": "PageBrief",
    "default_popup": "popup.html"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
