{
  "manifest_version": 3,
  "name": "PageBrief",
  "version": "0.4.1",
  "description": "Synthèse utile d'une page web dans un panneau latéral propre, par vues, avec historique de session.",
  "action": {
    "default_title": "Ouvrir PageBrief"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],
  "side_panel": {
    "default_path": "panel.html"
  }
}
