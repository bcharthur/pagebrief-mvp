APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=*

# Mets false si tu veux tester sans LLM
LLM_ENABLED=true
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT_S=180
LLM_MAX_OUTPUT_TOKENS=220
LLM_KEEP_ALIVE=10m

FETCH_TIMEOUT_S=20
MAX_INPUT_CHARS=7000
PAGEBRIEF_USER_AGENT=PageBriefBot/0.1
LOG_LEVEL=INFO
